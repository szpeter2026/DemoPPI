# ============
# DemoPPI — 环境变量配置
# ============

# --------
# Supabase（必填）
# 项目 ref 见 supabase/README.md（acozjhpjidrucqonpkey）
# --------
NEXT_PUBLIC_SUPABASE_URL=https://acozjhpjidrucqonpkey.supabase.co
# 代码读 PUBLISHABLE_KEY（与 Dashboard「anon / public」key 相同，二选一填写即可）
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# 仅服务端：小程序 auth.admin、trust_fss_records 写入等（构建可不填，运行相关 API 会失败）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --------
# 种子邀请码（冷启动用，仅首个用户注册时需要）
# 设置一个只有你自己知道的强邀请码，如：7A3B9F2C
# 设为空或不设置则禁用种子码（纯数据库邀请码模式）
# --------
SEED_INVITE_CODE=

# --------
# 站点 URL（SSR/重定向用）
# --------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --------
# Tatha 整合（付费版引导）
# DemoPPI 作为免费版，引导用户升级到 Tatha 付费版
# --------
# Tatha 后端地址（用于升级引导和跳转）
NEXT_PUBLIC_TATHA_URL=http://127.0.0.1:8010

# 客户端种子邀请码（与 SEED_INVITE_CODE 保持一致，前端注册校验用）
NEXT_PUBLIC_SEED_INVITE_CODE=

# --------
# Trust FSS 0.1（可选 · Nazha Verifier @ :5200）
# 合同：SurfaceZervi/docs/TRUST_FSS_PPI_0.1.md
# --------
TRUST_VERIFIER_URL=http://127.0.0.1:5200
# false = 投票 API 不强制验证据；true = 投票前须 functional_status=normal
TRUST_FSS_ENABLED=false

# --------
# 微信小程序配置
# 在微信公众平台 mp.weixin.qq.com 获取
# 开发阶段可不配置，系统会使用 mock openid
# --------
WX_MINIPROGRAM_APPID=
WX_MINIPROGRAM_SECRET=
